AccessType=rw
DefaultValue=0

[2000sub2]
ParameterName=Ttoggle
DataType=0x0005
AccessType=rw
DefaultValue=3

[2000sub3]
ParameterName=Ntoggle
DataType=0x0005
AccessType=rw
DefaultValue=5

[2000sub4]
ParameterName=Ctoggle
DataType=0x0005
AccessType=rw

