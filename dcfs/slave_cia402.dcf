[20A0]
ParameterName=Load-side encoder position
DataType=0x0004
AccessType=ro
DefaultValue=0x00000000
PDOMapping=1

; 0x2240 — Motor encoder position [pulse] (ro)
[2240]
ParameterName=Motor encoder position
DataType=0x0004
AccessType=ro
DefaultValue=0x00000000

; 0x3B68 — Warning code (ro)
