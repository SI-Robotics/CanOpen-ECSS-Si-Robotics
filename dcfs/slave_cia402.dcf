; ── Communication ────────────────────────────────────────────────────────────

; SYNC COB-ID — bit 30 = slave is SYNC producer
[1005]
ParameterName=COB-ID SYNC
DataType=0x0007
AccessType=rw
ParameterValue=0x40000080
DefaultValue=0x00000080

; SYNC cycle period: 1 000 000 us = 1 s
[1006]
ParameterName=Communication cycle period
DataType=0x0007
AccessType=rw
DefaultValue=1000000

; Consumer heartbeat: monitor master 0x01, timeout 550 ms
; (0x01 << 16) | 550 = 0x00010226
[1016]
SubNumber=2
ParameterName=Consumer heartbeat time
ObjectType=0x08

[1016sub0]
ParameterName=Highest sub-index supported
DataType=0x0005
AccessType=const
DefaultValue=0x01

[1016sub1]
ParameterName=Consumer heartbeat time
DataType=0x0007
AccessType=rw
DefaultValue=0x00010226

; Producer heartbeat: 500 ms
[1017]
ParameterName=Producer heartbeat time
DataType=0x0006
AccessType=rw
DefaultValue=500

; Synchronous counter overflow value
[1019]
ParameterName=Synchronous counter overflow value
DataType=0x0005
AccessType=rw
DefaultValue=16

; RPDO1: receives Controlword + Target position from master (COB-ID 0x181)
[1400]
SubNumber=3
ParameterName=RPDO1 communication parameter
ObjectType=0x09

[1400sub0]
ParameterName=Highest sub-index supported
DataType=0x0005
AccessType=const
DefaultValue=0x02

[1400sub1]
ParameterName=COB-ID used by RPDO
DataType=0x0007
AccessType=rw
DefaultValue=0x181

[1400sub2]
ParameterName=Transmission type
DataType=0x0005
AccessType=rw
DefaultValue=0x01

; RPDO1 mapping: Controlword 0x6040 (16bit) + Target position 0x607A (32bit)
[1600]
ParameterName=RPDO1 mapping parameter
ObjectType=0x09
DataType=0x0007
AccessType=rw
CompactSubObj=2

[1600Value]
NrOfEntries=2
1=0x60400010
2=0x607A0020

; TPDO1: sends Statusword + Actual position to master (COB-ID = 0x180 + NodeID)
[1800]
SubNumber=3
ParameterName=TPDO1 communication parameter
ObjectType=0x09

[1800sub0]
ParameterName=Highest sub-index supported
DataType=0x0005
AccessType=const
DefaultValue=0x02

[1800sub1]
ParameterName=COB-ID used by TPDO
DataType=0x0007
AccessType=rw
DefaultValue=$NODEID+0x180

[1800sub2]
ParameterName=Transmission type
DataType=0x0005
AccessType=rw
DefaultValue=0x01

; TPDO1 mapping: Statusword 0x6041 (16bit) + Actual position 0x6064 (32bit)
[1A00]
ParameterName=TPDO1 mapping parameter
ObjectType=0x09
DataType=0x0007
AccessType=rw
CompactSubObj=2

[1A00Value]
NrOfEntries=2
1=0x60410010
2=0x60640020

; NMT startup: slave stays in Pre-Operational (bit 2 = 1)
[1F80]
ParameterName=NMT startup
DataType=0x0007
AccessType=rw
DefaultValue=0x00000004

; ── CiA 402 Drive Profile Objects ────────────────────────────────────────────

; 0x603F — Error code (ro)
[603F]
ParameterName=Error code
DataType=0x0006
AccessType=ro
DefaultValue=0x0000

; 0x6040 — Controlword (rw, RxPDO)
; Shutdown=0x0006, SwitchOn=0x0007, EnableOp=0x000F, FaultReset=0x0080, QuickStop=0x0002
[6040]
ParameterName=Controlword
DataType=0x0006
AccessType=rw
DefaultValue=0x0000
PDOMapping=1

; 0x6041 — Statusword (ro, TxPDO)
; Mask 0x006F: 0x0040=SwOnDisabled, 0x0021=ReadyToSwOn, 0x0023=SwitchedOn
;              0x0027=OpEnabled, 0x000F=Fault
[6041]
ParameterName=Statusword
DataType=0x0006
AccessType=ro
DefaultValue=0x0000
PDOMapping=1

; 0x605A — Quick stop option code (2 = decelerate on quick stop ramp)
[605A]
ParameterName=Quick stop option code
DataType=0x0003
AccessType=rw
DefaultValue=0x0002

; 0x605B — Shutdown option code
[605B]
ParameterName=Shutdown option code
DataType=0x0003
AccessType=rw
DefaultValue=0x0000

; 0x605C — Disable operation option code
[605C]
ParameterName=Disable operation option code
DataType=0x0003
AccessType=rw
DefaultValue=0x0000

; 0x605D — Halt option code (1 = decelerate on profile decel)
[605D]
ParameterName=Halt option code
DataType=0x0003
AccessType=rw
DefaultValue=0x0001

; 0x605E — Fault reaction option code (1 = quick stop)
[605E]
ParameterName=Fault reaction option code
DataType=0x0003
AccessType=rw
DefaultValue=0x0001

; 0x6060 — Modes of operation (rw)
; 1=PP, 3=PV, 4=PT, 6=HM, 8=CSP, 9=CSV, 10=CST
[6060]
ParameterName=Modes of operation
DataType=0x0002
AccessType=rw
DefaultValue=0x08
PDOMapping=1

