[DeviceInfo]
VendorName=N7 Space Sp. z o.o.
VendorNumber=0x004E3753
BaudRate_10=1
BaudRate_20=1
BaudRate_50=1
BaudRate_125=1
BaudRate_250=1
BaudRate_500=1
BaudRate_800=1
BaudRate_1000=1

[DeviceComissioning]
NodeID=0x01

; =============================================================================
; Mandatory Objects  (0x1000-0x1FFF)
; =============================================================================
[MandatoryObjects]
SupportedObjects=3
1=0x1000
2=0x1001
3=0x1018

[1000]
ParameterName=Device type
DataType=0x0007
AccessType=ro

[1001]
ParameterName=Error register
DataType=0x0005
AccessType=ro

[1018]
SubNumber=5
ParameterName=Identity object
ObjectType=0x09

[1018sub0]
ParameterName=Highest sub-index supported
DataType=0x0005
AccessType=const
DefaultValue=0x04

[1018sub1]
ParameterName=Vendor-ID
DataType=0x0007
AccessType=ro
DefaultValue=0x004E3753

[1018sub2]
ParameterName=Product code
DataType=0x0007
AccessType=ro

[1018sub3]
ParameterName=Revision number
DataType=0x0007
AccessType=ro

[1018sub4]
ParameterName=Serial number
DataType=0x0007
AccessType=ro

; =============================================================================
; Optional Objects  (0x1000-0x1FFF communication + 0x6000-0x9FFF CiA 402)
; dcf2dev requires ALL 0x6000+ objects here, NOT in ManufacturerObjects
; =============================================================================
[OptionalObjects]
SupportedObjects=27
1=0x1005
2=0x1006
3=0x1016
4=0x1017
5=0x1019
6=0x1280
7=0x1400
8=0x1600
9=0x1800
10=0x1A00
11=0x1F80
12=0x1F81
13=0x6040
14=0x6041
15=0x6060
16=0x6061
17=0x6064
18=0x6065
19=0x6071
20=0x6072
21=0x6077
22=0x607A
23=0x6081
24=0x60B1
25=0x60B2
26=0x60FF
27=0x6502

; ── Communication ────────────────────────────────────────────────────────────

; SYNC consumer COB-ID (master does not produce SYNC)
[1005]
ParameterName=COB-ID SYNC
DataType=0x0007
AccessType=rw
DefaultValue=0x00000080

; Communication cycle period (used by SDO reconfiguration of slave)
[1006]
ParameterName=Communication cycle period
DataType=0x0007
AccessType=rw
DefaultValue=1000000

; Consumer heartbeat: monitor slave 0x02, timeout 550 ms
; (0x02 << 16) | 550 = 0x00020226
[1016]
SubNumber=2
ParameterName=Consumer heartbeat time
ObjectType=0x08

[1016sub0]
ParameterName=Highest sub-index supported
DataType=0x0005
AccessType=const
DefaultValue=0x01

[1016sub1]
ParameterName=Consumer heartbeat time
DataType=0x0007
AccessType=rw
DefaultValue=0x00020226

; Producer heartbeat: 500 ms (slave redundancy manager monitors this)
[1017]
ParameterName=Producer heartbeat time
DataType=0x0006
AccessType=rw
DefaultValue=500

; Synchronous counter overflow value
[1019]
ParameterName=Synchronous counter overflow value
DataType=0x0005
AccessType=rw
DefaultValue=16

; SDO client — communicate with slave node 0x02
; COB-ID client→server: 0x600 + 0x02 = 0x602
; COB-ID server→client: 0x580 + 0x02 = 0x582
[1280]
SubNumber=4
ParameterName=SDO client parameter
ObjectType=0x09

[1280sub0]
ParameterName=Highest sub-index supported
DataType=0x0005
AccessType=const
DefaultValue=0x03

[1280sub1]
ParameterName=COB-ID client to server (tx)
DataType=0x0007
AccessType=rw
DefaultValue=0x00000602

[1280sub2]
ParameterName=COB-ID server to client (rx)
DataType=0x0007
AccessType=rw
DefaultValue=0x00000582

[1280sub3]
ParameterName=Node-ID of the SDO server
DataType=0x0005
AccessType=rw
DefaultValue=0x02

; RPDO1: receives Statusword + Actual position from slave (COB-ID 0x182)
[1400]
SubNumber=3
ParameterName=RPDO1 communication parameter
ObjectType=0x09

[1400sub0]
ParameterName=Highest sub-index supported
DataType=0x0005
AccessType=const
DefaultValue=0x02

[1400sub1]
ParameterName=COB-ID used by RPDO
DataType=0x0007
AccessType=rw
DefaultValue=0x182

[1400sub2]
ParameterName=Transmission type
DataType=0x0005
AccessType=rw
DefaultValue=0x01

; RPDO1 mapping: Statusword 0x6041 (16bit) + Actual position 0x6064 (32bit)
[1600]
ParameterName=RPDO1 mapping parameter
ObjectType=0x09
DataType=0x0007
AccessType=rw
CompactSubObj=2

[1600Value]
NrOfEntries=2
1=0x60410010
2=0x60640020

; TPDO1: sends Controlword + Target position to slave (COB-ID = 0x180 + NodeID)
[1800]
SubNumber=3
ParameterName=TPDO1 communication parameter
ObjectType=0x09

[1800sub0]
ParameterName=Highest sub-index supported
DataType=0x0005
AccessType=const
DefaultValue=0x02

[1800sub1]
ParameterName=COB-ID used by TPDO
DataType=0x0007
AccessType=rw
DefaultValue=$NODEID+0x180

[1800sub2]
ParameterName=Transmission type
DataType=0x0005
AccessType=rw
DefaultValue=0x01

; TPDO1 mapping: Controlword 0x6040 (16bit) + Target position 0x607A (32bit)
[1A00]
ParameterName=TPDO1 mapping parameter
ObjectType=0x09
DataType=0x0007
AccessType=rw
CompactSubObj=2

[1A00Value]
NrOfEntries=2
1=0x60400010
2=0x607A0020

; NMT startup: bit 0 = this is NMT master
[1F80]
ParameterName=NMT startup
DataType=0x0007
AccessType=rw
ParameterValue=0x00000001

; NMT slave assignment: slave node 0x02
[1F81]
ParameterName=NMT slave assignment
ObjectType=0x08
DataType=0x0007
AccessType=rw
CompactSubObj=2

[1F81Value]
NrOfEntries=1
2=0x00000001

; ── CiA 402 Mirror Objects ────────────────────────────────────────────────────
; Master holds local copies of what it sends to / receives from the slave.
; Updated by lely-core via PDO exchanges.

; 0x6040 — Controlword (rw, TxPDO mapped — master sends to slave)
; Shutdown=0x0006, SwitchOn=0x0007, EnableOp=0x000F
; FaultReset: write 0x0080 then 0x0006
; QuickStop=0x0002
[6040]
ParameterName=Controlword
DataType=0x0006
AccessType=rw
DefaultValue=0x0000
PDOMapping=1

; 0x6041 — Statusword (ro, RxPDO mapped — master receives from slave)
; Mask 0x006F: 0x0040=SwOnDisabled, 0x0021=ReadyToSwOn
;              0x0023=SwitchedOn,   0x0027=OpEnabled, 0x000F=Fault
[6041]
ParameterName=Statusword
DataType=0x0006
AccessType=rw
DefaultValue=0x0000
PDOMapping=1

; 0x6060 — Modes of operation (sent to slave via SDO)
; 1=PP, 3=PV, 4=PT, 8=CSP, 9=CSV, 10=CST
[6060]
ParameterName=Modes of operation
DataType=0x0002
AccessType=rw
DefaultValue=0x08

; 0x6061 — Modes of operation display (read from slave via SDO)
[6061]
ParameterName=Modes of operation display
DataType=0x0002
AccessType=rw
DefaultValue=0x00

; 0x6064 — Position actual value [pulse] (ro, RxPDO mapped)
[6064]
ParameterName=Position actual value
DataType=0x0004
AccessType=rw
DefaultValue=0x00000000
PDOMapping=1

; 0x6065 — Following error window [pulse]
[6065]
ParameterName=Following error window
DataType=0x0007
AccessType=rw
DefaultValue=0x00000001

; 0x6071 — Target torque [1/1000 rated]
[6071]
ParameterName=Target torque
DataType=0x0003
AccessType=rw
DefaultValue=0x0000

; 0x6072 — Max torque [1/1000 rated]
[6072]
ParameterName=Max torque
DataType=0x0006
AccessType=rw
DefaultValue=0x0000

; 0x6077 — Torque actual value [1/1000 rated] (ro)
[6077]
ParameterName=Torque actual value
DataType=0x0003
AccessType=ro
DefaultValue=0x0000

; 0x607A — Target position [pulse] (rw, TxPDO mapped — master sends to slave)
[607A]
ParameterName=Target position
DataType=0x0004
AccessType=rw
DefaultValue=0x00000000
PDOMapping=1

; 0x6081 — Profile velocity [pulse/s]
[6081]
ParameterName=Profile velocity
DataType=0x0007
AccessType=rw
DefaultValue=0x00000000

; 0x60B1 — Velocity offset [pulse/s] (CSP feed-forward)
[60B1]
ParameterName=Velocity offset
DataType=0x0004
AccessType=rw
DefaultValue=0x00000000

; 0x60B2 — Torque offset [1/1000 rated] (CSP feed-forward)
[60B2]
ParameterName=Torque offset
DataType=0x0003
AccessType=rw
DefaultValue=0x0000

; 0x60FF — Target velocity [pulse/s] (CSV mode)
[60FF]
ParameterName=Target velocity
DataType=0x0004
AccessType=rw
DefaultValue=0x00000000

; 0x6502 — Supported drive modes (ro)
[6502]
ParameterName=Supported drive modes
DataType=0x0007
AccessType=ro
DefaultValue=0x000003CD

; =============================================================================
; Manufacturer-Specific Objects  (0x2000-0x5FFF only)
; =============================================================================
[ManufacturerObjects]
SupportedObjects=1
1=0x2000

; Redundancy object: Bdefault = 0 (start on bus A)
[2000]
SubNumber=2
ParameterName=Redundancy object
ObjectType=0x09

[2000sub0]
ParameterName=Highest sub-index supported
DataType=0x0005
AccessType=const
DefaultValue=0x01

[2000sub1]
ParameterName=Bdefault
DataType=0x0005
AccessType=rw
DefaultValue=0
