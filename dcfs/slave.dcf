DataType=0x0005
AccessType=ro

; SYNC COB-ID: bit 30 set = this node is the SYNC producer
[1005]
ParameterName=COB-ID SYNC
DataType=0x0007
AccessType=rw
ParameterValue=0x40000080
DefaultValue=0x00000080

; SYNC cycle period: 1,000,000 us = 1 second
[1006]
ParameterName=Communication cycle period
DataType=0x0007
AccessType=rw
DefaultValue=1000000

; Consumer heartbeat: monitor master Node 0x01 with 550ms timeout
; Value = (0x01 << 16) | 550 = 0x00010226
[1016]
SubNumber=2
ParameterName=Consumer heartbeat time
ObjectType=0x08

[1016sub0]
ParameterName=Highest sub-index supported
DataType=0x0005
AccessType=const
DefaultValue=0x01

[1016sub1]
ParameterName=Consumer heartbeat time
DataType=0x0007
AccessType=rw
DefaultValue=0x00010226

; Heartbeat producer: 500ms
[1017]
