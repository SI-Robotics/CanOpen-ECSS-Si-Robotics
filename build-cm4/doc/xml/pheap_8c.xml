        <definition>void pheap_insert</definition>
        <argsstring>(struct pheap *heap, struct pnode *node)</argsstring>
        <name>pheap_insert</name>
        <param>
          <type>struct <ref refid="structpheap" kindref="compound">pheap</ref> *</type>
