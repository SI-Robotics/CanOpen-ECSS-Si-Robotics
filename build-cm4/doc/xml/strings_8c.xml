        <type>int</type>
        <definition>int lely_compat_strcasecmp</definition>
        <argsstring>(const char *s1, const char *s2)</argsstring>
        <name>lely_compat_strcasecmp</name>
        <param>
          <type>const char *</type>
          <declname>s1</declname>
        </param>
        <param>
          <type>const char *</type>
          <declname>s2</declname>
        </param>
        <briefdescription>
<para>Compares the string at <bold>s1</bold> to the string at <bold>s2</bold>, ignoring differences in case. </para>
        </briefdescription>
        <detaileddescription>
<para><simplesect kind="return"><para>an integer greater than, equal to, or less than 0 if the string at <bold>s1</bold> is greater than, equal to, or less than the string at <bold>s2</bold>. </para>
</simplesect>
</para>
        </detaileddescription>
