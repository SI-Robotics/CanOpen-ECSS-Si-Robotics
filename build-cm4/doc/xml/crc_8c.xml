      <memberdef kind="function" id="crc_8c_1a35ba16d71094133c2810f6d0511b8c92" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>uint_least16_t</type>
        <definition>uint_least16_t co_crc</definition>
        <argsstring>(uint_least16_t crc, const uint_least8_t *bp, size_t n)</argsstring>
        <name>co_crc</name>
        <param>
          <type>uint_least16_t</type>
          <declname>crc</declname>
        </param>
        <param>
          <type>const uint_least8_t *</type>
          <declname>bp</declname>
        </param>
        <param>
          <type>size_t</type>
          <declname>n</declname>
        </param>
        <briefdescription>
<para>Computes a CRC-16 checksum. </para>
        </briefdescription>
        <detaileddescription>
<para>This is an implementation of the CRC16-CCITT specification based on the 0x1021 generator polynomial. It uses a table with precomputed values for efficiency.</para>
<para>As per section 7.2.4.3.16 in CiA 301 version 4.2.0, the CRC of &quot;123456789&quot; (with an initial value of 0x0000) is 0x31c3.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>crc</parametername>
</parameternamelist>
<parameterdescription>
<para>the initial value. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>bp</parametername>
</parameternamelist>
<parameterdescription>
<para>a pointer to the bytes to be hashed. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>n</parametername>
</parameternamelist>
<parameterdescription>
<para>the number of bytes to hash.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>the updated CRC. </para>
</simplesect>
</para>
        </detaileddescription>
