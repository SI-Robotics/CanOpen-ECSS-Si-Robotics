      <memberdef kind="define" id="cmp_8h_1a45cfa8334d8d1fa8d3e3fbf9aa51e9b3" prot="public" static="no">
        <name>LELY_UTIL_DEFINE_TYPE</name>
        <param><defname>name</defname></param>
        <param><defname>type</defname></param>
        <initializer>	inline int name##_cmp(const void *p1, const void *p2) \
	{ \
		if (p1 == p2) \
			return 0; \
\
		if (!p1) \
			return -1; \
		if (!p2) \
			return 1; \
\
		type v1 = *(const type *)p1; \
		type v2 = *(const type *)p2; \
		return (v2 &lt; v1) - (v1 &lt; v2); \
	}</initializer>
        <briefdescription>
        </briefdescription>
        <detaileddescription>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
