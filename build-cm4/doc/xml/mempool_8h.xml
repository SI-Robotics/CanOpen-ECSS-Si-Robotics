        <definition>alloc_t* mempool_init</definition>
        <argsstring>(struct mempool *pool, void *memory, size_t size)</argsstring>
        <name>mempool_init</name>
        <param>
          <type>struct <ref refid="structmempool" kindref="compound">mempool</ref> *</type>
          <declname>pool</declname>
        </param>
        <param>
          <type>void *</type>
