        <name>co_nmt_hb_t</name>
        <briefdescription>
<para>An opaque CANopen NMT heartbeat consumer type. </para>
        </briefdescription>
        <detaileddescription>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
