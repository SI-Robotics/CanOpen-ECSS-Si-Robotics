      <memberdef kind="function" id="nmt__hb_8h_1ade97b13bd684ed8f0786c3ca045ab121" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void co_nmt_hb_ind</definition>
        <argsstring>(co_nmt_t *nmt, co_unsigned8_t id, co_nmt_ec_state_t state, co_nmt_ec_reason_t reason, co_unsigned8_t st)</argsstring>
        <name>co_nmt_hb_ind</name>
        <param>
          <type><ref refid="include_2lely_2co_2co_8h_1a12fe9d436d20874aa033404946a30000" kindref="member">co_nmt_t</ref> *</type>
          <declname>nmt</declname>
        </param>
        <param>
          <type>co_unsigned8_t</type>
          <declname>id</declname>
        </param>
        <param>
          <type><ref refid="nmt_8h_1a43f9cb87172e9294b661d7fce3bb6534" kindref="member">co_nmt_ec_state_t</ref></type>
          <declname>state</declname>
        </param>
        <param>
          <type><ref refid="nmt_8h_1ada8e39ee33acdaca72f81a65934d01cc" kindref="member">co_nmt_ec_reason_t</ref></type>
          <declname>reason</declname>
        </param>
        <param>
          <type>co_unsigned8_t</type>
          <declname>st</declname>
        </param>
        <briefdescription>
<para>The CANopen NMT heartbeat indication function, invoked when a heartbeat event occurs. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>nmt</parametername>
</parameternamelist>
<parameterdescription>
<para>a pointer to an NMT master/slave service. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>id</parametername>
</parameternamelist>
<parameterdescription>
<para>the node-ID (in the range [1..127]). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>state</parametername>
</parameternamelist>
<parameterdescription>
<para>indicates whether the event occurred (<ref refid="nmt_8h_1aa4260852c472279ae9839a29319b9a78a9a7a1f2ca9d3b5ddd0421006412de5ac" kindref="member">CO_NMT_EC_OCCURRED</ref>) or was resolved (<ref refid="nmt_8h_1aa4260852c472279ae9839a29319b9a78aaf807830442432d4a6f57094d21d3e1d" kindref="member">CO_NMT_EC_RESOLVED</ref>). Note that heartbeat state change events only occur and are never resolved. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>reason</parametername>
</parameternamelist>
<parameterdescription>
<para>indicates whether the event occurred because of a timeout (<ref refid="nmt_8h_1a3064c748aafccad0447f9ce06179fb2caa823145c981a391750ee1698e4187cac" kindref="member">CO_NMT_EC_TIMEOUT</ref>) or a state change (<ref refid="nmt_8h_1a3064c748aafccad0447f9ce06179fb2ca7db00cb951a2ca19ea157d5a90fdc8e9" kindref="member">CO_NMT_EC_STATE</ref>). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>st</parametername>
</parameternamelist>
<parameterdescription>
<para>the state of the node (if <bold>reason</bold> is <ref refid="nmt_8h_1a3064c748aafccad0447f9ce06179fb2ca7db00cb951a2ca19ea157d5a90fdc8e9" kindref="member">CO_NMT_EC_STATE</ref>). </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
