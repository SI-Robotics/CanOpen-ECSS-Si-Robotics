      <memberdef kind="define" id="lely-cpputest-ext_8hpp_1ac81a55ed42c6feee4efcbade8148454f" prot="public" static="no">
        <name>FUNCTIONPOINTER_NOT_NULL</name>
        <param><defname>ptr</defname></param>
        <initializer>  do { \
    auto* const ptr_val = (ptr); \
    static_assert( \
        std::is_function&lt; \
            typename std::remove_pointer&lt;decltype(ptr_val)&gt;::type&gt;::value, \
        &quot;FUNCTIONPOINTER_NOT_NULL(): &apos;ptr&apos; is not a function pointer&quot;); \
    CHECK(ptr_val != nullptr); \
    assert(ptr_val); \
  } while (false)</initializer>
