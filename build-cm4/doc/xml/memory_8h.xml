      <memberdef kind="function" id="memory_8h_1aa42e1e26c4edb6451b7f1f2f3c87e5c3" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void mem_free</definition>
        <argsstring>(alloc_t *alloc, void *ptr)</argsstring>
        <name>mem_free</name>
        <param>
          <type><ref refid="memory_8h_1a693f639f300fc9b0fb65dbf8c817ecc3" kindref="member">alloc_t</ref> *</type>
          <declname>alloc</declname>
        </param>
        <param>
          <type>void *</type>
          <declname>ptr</declname>
        </param>
        <briefdescription>
<para>Frees space for an object previously allocated by <ref refid="memory_8h_1a90830d17a2e79efd7d376803588fad48" kindref="member">mem_alloc()</ref>. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>alloc</parametername>
</parameternamelist>
<parameterdescription>
<para>a pointer to a memory allocator. If <bold>alloc</bold> is NULL, the default memory allocator is used. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>ptr</parametername>
</parameternamelist>
<parameterdescription>
<para>a pointer to the space to be freed. If <bold>ptr</bold> is NULL, no action occurs. Otherwise, <bold>ptr</bold> MUST point to space that has been previously allocated by <bold>alloc</bold> and has not not yet freed. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
