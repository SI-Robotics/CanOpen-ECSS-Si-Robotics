      <memberdef kind="function" id="ustring_8h_1ac92769e1ef28e06b193d4f496ae3981a" prot="public" static="no" const="no" explicit="no" inline="yes" virt="non-virtual">
        <type>char16_t *</type>
        <definition>char16_t * str16ncpy</definition>
        <argsstring>(char16_t *dst, const char16_t *src, size_t n)</argsstring>
        <name>str16ncpy</name>
        <param>
          <type>char16_t *</type>
          <declname>dst</declname>
        </param>
        <param>
          <type>const char16_t *</type>
          <declname>src</declname>
        </param>
        <param>
          <type>size_t</type>
          <declname>n</declname>
        </param>
        <briefdescription>
<para>Copies <bold>n</bold> (16-bit) Unicode characters from the string at <bold>src</bold> to <bold>dst</bold>. </para>
        </briefdescription>
        <detaileddescription>
<para>If the string at <bold>src</bold> is shorter than <bold>n</bold> characters, NUL characters are appended to the string at <bold>dst</bold> until <bold>n</bold> characters haven been written.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>dst</parametername>
</parameternamelist>
<parameterdescription>
<para>the destination address, which MUST be large enough to hold the string. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>src</parametername>
</parameternamelist>
<parameterdescription>
<para>a pointer to the string to be copied. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>n</parametername>
</parameternamelist>
<parameterdescription>
<para>the number of (16-bit) Unicode characters to copy.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><bold>dst</bold>. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
