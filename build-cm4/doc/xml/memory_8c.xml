      <memberdef kind="function" id="memory_8c_1a90830d17a2e79efd7d376803588fad48" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void *</type>
        <definition>void* mem_alloc</definition>
        <argsstring>(alloc_t *alloc, size_t alignment, size_t size)</argsstring>
        <name>mem_alloc</name>
        <param>
          <type><ref refid="memory_8h_1a693f639f300fc9b0fb65dbf8c817ecc3" kindref="member">alloc_t</ref> *</type>
          <declname>alloc</declname>
        </param>
        <param>
          <type>size_t</type>
          <declname>alignment</declname>
        </param>
        <param>
          <type>size_t</type>
          <declname>size</declname>
        </param>
        <briefdescription>
<para>Allocates space for an object of the specified alignmend and size. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>alloc</parametername>
</parameternamelist>
<parameterdescription>
<para>a pointer to a memory allocator. If <bold>alloc</bold> is NULL, the default memory allocator is used. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>alignment</parametername>
</parameternamelist>
<parameterdescription>
<para>the alignment (in bytes) of the space to be allocated. <bold>alignment</bold> MUST be an integral multiple of 2. If <bold>alignment</bold> is 0, the default alignment is used. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>size</parametername>
</parameternamelist>
<parameterdescription>
<para>the number of bytes to allocate. <bold>size</bold> is rounded up to the nearest integral multiple if <bold>alignment</bold>.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
returns a pointer to the allocated space, or NULL on error. In the latter case, the error code can be obtained with <ref refid="error_8h_1a501e5c693244531fd60a57b69f3744b8" kindref="member">get_errc()</ref>. </para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="lib/util/memory.c" line="62" column="1" bodyfile="lib/util/memory.c" bodystart="62" bodyend="70"/>
      </memberdef>
      <memberdef kind="function" id="memory_8c_1aa42e1e26c4edb6451b7f1f2f3c87e5c3" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void mem_free</definition>
        <argsstring>(alloc_t *alloc, void *ptr)</argsstring>
        <name>mem_free</name>
        <param>
          <type><ref refid="memory_8h_1a693f639f300fc9b0fb65dbf8c817ecc3" kindref="member">alloc_t</ref> *</type>
          <declname>alloc</declname>
        </param>
        <param>
          <type>void *</type>
          <declname>ptr</declname>
        </param>
        <briefdescription>
<para>Frees space for an object previously allocated by <ref refid="memory_8h_1a90830d17a2e79efd7d376803588fad48" kindref="member">mem_alloc()</ref>. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>alloc</parametername>
</parameternamelist>
<parameterdescription>
<para>a pointer to a memory allocator. If <bold>alloc</bold> is NULL, the default memory allocator is used. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>ptr</parametername>
</parameternamelist>
<parameterdescription>
<para>a pointer to the space to be freed. If <bold>ptr</bold> is NULL, no action occurs. Otherwise, <bold>ptr</bold> MUST point to space that has been previously allocated by <bold>alloc</bold> and has not not yet freed. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="lib/util/memory.c" line="73" column="1" bodyfile="lib/util/memory.c" bodystart="73" bodyend="81"/>
