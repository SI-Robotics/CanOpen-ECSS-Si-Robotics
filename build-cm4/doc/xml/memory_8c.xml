      <memberdef kind="function" id="memory_8c_1ac45d24195a7cd854df0667705f635e7c" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>size_t</type>
        <definition>size_t mem_size</definition>
        <argsstring>(const alloc_t *alloc)</argsstring>
        <name>mem_size</name>
        <param>
          <type>const <ref refid="memory_8h_1a693f639f300fc9b0fb65dbf8c817ecc3" kindref="member">alloc_t</ref> *</type>
          <declname>alloc</declname>
        </param>
        <briefdescription>
<para>Returns the total number of bytes allocated by a memory allocator, or 0 if the allocator does not track memory usage. </para>
        </briefdescription>
        <detaileddescription>
<para>Note that because of allocation overhead, the total size MAY be larger than the sum of the sizes specified to <ref refid="memory_8h_1a90830d17a2e79efd7d376803588fad48" kindref="member">mem_alloc()</ref>. </para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
