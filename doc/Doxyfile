# Nazwa projektu
PROJECT_NAME           = "CANopen CiA402"

# Wersja
PROJECT_NUMBER         = "1.0"

# Gdzie są pliki źródłowe (relatywnie do Doxyfile)
INPUT                  = ./Inc ./Src

# Szukaj rekurencyjnie w podkatalogach
RECURSIVE              = YES

# Jakie rozszerzenia
FILE_PATTERNS          = *.c *.h

# Gdzie wygenerować dokumentację
OUTPUT_DIRECTORY       = ./docs

# HTML output
GENERATE_HTML          = YES

# LaTeX (PDF) – wyłącz jeśli nie potrzebujesz
GENERATE_LATEX         = NO

# Pokaż wszystkie elementy (łącznie ze static)
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = YES

# Grafy zależności między plikami (wymaga graphviz)
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
INCLUDE_GRAPH          = YES

# Numerowane sekcje
SORT_MEMBER_DOCS       = NO
